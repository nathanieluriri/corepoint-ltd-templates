DirectoryIndex index.html
RewriteEngine On

# Canonical host/protocol
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.corepointltd\.com$ [NC]
RewriteRule ^ https://www.corepointltd.com%{REQUEST_URI} [L,R=301,NE]

# Canonical homepage path
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [L,R=301]

# Keep existing files and folders untouched
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pretty URLs: /about -> /about.html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
Redirect 301 /portfolio-details /
Redirect 301 /starter-page /
